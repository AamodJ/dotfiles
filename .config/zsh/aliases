# Aliases 

## zsh specific 
alias resource="source $XDG_CONFIG_HOME/zsh/.zshrc"

## pacman fuzzy finding
alias install-pac="pacman -Slq | fzf --multi --preview 'pacman -Si {1}' | xargs -ro sudo pacman -S"
alias rm-pac="pacman -Qq | fzf --multi --preview 'pacman -Qi {1}' | xargs -ro sudo pacman -Rns"

## Config files 
alias cfnv="$EDITOR $XDG_CONFIG_HOME/nvim/init.lua"
alias cfz="$EDITOR $XDG_CONFIG_HOME/zsh/.zshrc && clear && source $XDG_CONFIG_HOME/zsh/.zshrc"
alias cfzen="$EDITOR $XDG_CONFIG_HOME/zsh/.zshenv && source $XDG_CONFIG_HOME/zsh/.zshenv"
alias cfza="$EDITOR $XDG_CONFIG_HOME/zsh/aliases && source $XDG_CONFIG_HOME/zsh/aliases"
alias cflf="$EDITOR $XDG_CONFIG_HOME/lf/lfrc"
alias cflfs="$EDITOR $XDG_CONFIG_HOME/lf/scope"
alias cfk="$EDITOR $XDG_CONFIG_HOME/kitty/kitty.conf"

alias cfh="$EDITOR $XDG_CONFIG_HOME/hypr/hyprland.lua"
alias cfm="$EDITOR $XDG_CONFIG_HOME/mango/config.conf"

## Convenience
alias zat="zathura"
alias ts="sudo timeshift"
alias usage="sudo btrfs filesystem usage /"
alias sinks="pactl list short sinks"
alias :q="exit"
alias l="LC_COLLATE=C ls -p --color=auto --group-directories-first"
alias ll="LC_COLLATE=C ls -lahp --color=auto --group-directories-first"
alias ls="LC_COLLATE=C ls -lahp --color=auto --group-directories-first"
alias rg="rg 2> /dev/null"
alias hl="rg --passthru 2> /dev/null"
alias y="yay -Sy"
alias p="sudo pacman -Sy"
alias p1="ping 1.1.1.1"
alias pa="ping archlinux.org"
alias mons="hyprctl monitors all | less"
alias cls="hyprctl clients | less"

alias ldock="lazydocker"
alias pdc="podman compose down && printf '\n\nShutdown all containers complete\n\n' && podman compose up -d  "
alias pdd="podman compose down && printf '\n\nShutdown all containers complete\n'"

## Cleanup
alias wget="wget --hsts-file=\"$XDG_DATA_HOME/wget-hsts\""
alias adb='HOME="$XDG_DATA_HOME"/android adb'

## Vim aliases
alias v="$EDITOR"
alias vim="$EDITOR"
alias vi="$EDITOR"
alias vimdiff="nvim -d"

# Fun kitty features
alias diff="kitty +kitten diff"
alias gd="git difftool --no-symlinks --dir-diff"
alias gg="git log --oneline --graph"

# Ansible QOL
alias ag="ansible-galaxy"
alias ap="ansible-playbook"
alias aa="ansible"

# Autocorrect but actually good
alias chomd="chmod"
alias ..="echo 'cd ..' && cd .."
alias ncim="$VISUAL"
alias nxim="$VISUAL"

alias grep="grep --color=auto 2> /dev/null"
